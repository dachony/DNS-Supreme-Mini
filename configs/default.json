{
  "dns": {
    "listen_addr": "0.0.0.0",
    "port": 53,
    "forwarders": ["8.8.8.8:53", "1.1.1.1:53"],
    "cache_size": 5000,
    "cache_min_ttl": 10,
    "cache_max_ttl": 86400
  },
  "api": {
    "listen_addr": "0.0.0.0",
    "port": 8080
  },
  "block_page": {
    "listen_addr": "0.0.0.0",
    "http_port": 80,
    "https_port": 443
  },
  "logging": {
    "query_log": true,
    "retention_days": 7,
    "batch_size": 50,
    "flush_interval_seconds": 5
  },
  "data_dir": "/data"
}
